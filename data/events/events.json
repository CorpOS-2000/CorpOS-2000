[
  {
    "id": "evt_first_week_expenses_warning",
    "title": "Operating Expenses Notice",
    "type": "scheduled",
    "oneShot": true,
    "fireOnDay": 7,
    "fireOnHour": 9,
    "condition": { "type": "flag_not_set", "flag": "firstWeekWarningSent" },
    "dc": null,
    "outcomes": {
      "default": {
        "sms": {
          "from": "FRA",
          "message": "QUARTERLY NOTICE — Your operator account has been active for 7 days. Mandatory base operating expenses of $480/week are now being applied. Ensure your account maintains sufficient funds. Federal Revenue Authority."
        },
        "setFlag": "firstWeekWarningSent"
      }
    }
  },
  {
    "id": "evt_compliance_check_day3",
    "title": "Initial Compliance Scan",
    "type": "scheduled",
    "oneShot": true,
    "fireOnDay": 3,
    "fireOnHour": 14,
    "condition": { "type": "flag_not_set", "flag": "initialComplianceSent" },
    "dc": null,
    "outcomes": {
      "default": {
        "sms": {
          "from": "COMPLIANCE_MONITOR",
          "message": "Automated compliance scan complete. Your account has been active 3 days. No anomalies detected at this time. Activity logging is continuous per Mandate 2000-CR7."
        },
        "setFlag": "initialComplianceSent"
      }
    }
  },
  {
    "id": "evt_market_fluctuation",
    "title": "Market Movement",
    "type": "interval",
    "intervalHours": 48,
    "dc": 12,
    "modifiers": { "balance": true },
    "outcomes": {
      "pass": {
        "toast": {
          "title": "Market Update",
          "message": "Favorable conditions in your sector. Business sentiment is up.",
          "icon": "📈"
        }
      },
      "fail": {
        "toast": {
          "title": "Market Pressure",
          "message": "Sector headwinds this week. Conditions are tightening.",
          "icon": "📉"
        }
      }
    }
  },
  {
    "id": "evt_notoriety_spike_warning",
    "title": "Compliance Alert",
    "type": "triggered",
    "condition": { "type": "notoriety_above", "value": 50 },
    "oneShot": false,
    "dc": 14,
    "modifiers": { "notoriety": -1 },
    "outcomes": {
      "pass": {
        "sms": {
          "from": "COMPLIANCE_MONITOR",
          "message": "ALERT: Your operator compliance rating has entered the Non-Compliant tier. Continued irregularities may trigger formal review. Operator: {operatorId}"
        },
        "peek": {
          "sender": "Compliance Monitor",
          "message": "Compliance rating elevated — review your activity",
          "type": "compliance",
          "targetId": "COMPLIANCE_MONITOR",
          "icon": "⚠"
        }
      },
      "fail": {
        "notorietyDelta": 5,
        "sms": {
          "from": "COMPLIANCE_MONITOR",
          "message": "ESCALATION NOTICE: Compliance scan detected continued irregularities. Your file has been flagged for manual review. Operator: {operatorId}"
        }
      }
    }
  },
  {
    "id": "evt_low_funds_warning",
    "title": "Low Balance Warning",
    "type": "triggered",
    "condition": { "type": "bank_balance_below", "value": 1000 },
    "dc": null,
    "outcomes": {
      "default": {
        "sms": {
          "from": "FRA",
          "message": "LOW BALANCE NOTICE: Your primary account is below $1,000. Mandatory operating expenses of $68.57/day continue to apply. Insufficient funds will trigger a compliance review."
        },
        "peek": {
          "sender": "FRA",
          "message": "Account balance critically low — action required",
          "type": "compliance",
          "targetId": "FRA",
          "icon": "⚠"
        }
      }
    }
  },
  {
    "id": "evt_website_first_publish",
    "title": "Website Published",
    "type": "triggered",
    "oneShot": true,
    "condition": { "type": "website_published" },
    "dc": null,
    "outcomes": {
      "default": {
        "toast": {
          "title": "Website Live",
          "message": "Your site is indexed and receiving its first visitors.",
          "icon": "🌐"
        },
        "setFlag": "firstWebsitePublished"
      }
    }
  },
  {
    "id": "evt_audit_trigger_day14",
    "title": "Scheduled Compliance Review",
    "type": "scheduled",
    "oneShot": true,
    "fireOnDay": 14,
    "fireOnHour": 10,
    "condition": { "type": "notoriety_above", "value": 25 },
    "dc": 13,
    "modifiers": { "notoriety": -1 },
    "outcomes": {
      "pass": {
        "sms": {
          "from": "CORPOS_SYSTEM",
          "message": "SCHEDULED REVIEW — Day 14 compliance review has been initiated. Please stand by."
        },
        "triggerAudit": 1
      },
      "fail": {
        "notorietyDelta": 10,
        "sms": {
          "from": "CORPOS_SYSTEM",
          "message": "COMPLIANCE NOTICE — Irregularities detected in Day 14 review. Enhanced monitoring applied to your operator account."
        }
      }
    }
  },
  {
    "id": "evt_website_contract_offer_day5",
    "title": "Website Development Contract",
    "type": "scheduled",
    "oneShot": true,
    "fireOnDay": 5,
    "fireOnHour": 10,
    "condition": { "type": "flag_not_set", "flag": "firstWebsiteContractOffered" },
    "dc": null,
    "outcomes": {
      "default": {
        "sms": {
          "from": "ACT-KYLE-HARGROVE",
          "message": "Hey — one of our partner companies is looking for someone to build their WorldNet presence. Pays $4,500 on delivery. They need a published site with at least a Hero Banner and a Contact Form. Interested? Open WebEx Publisher when you're ready."
        },
        "setFlag": "firstWebsiteContractOffered",
        "scheduleFollowUp": {
          "eventId": "evt_website_contract_create",
          "delayHours": 0.1
        }
      }
    }
  },
  {
    "id": "evt_website_contract_create",
    "title": "Create Website Contract",
    "type": "triggered",
    "oneShot": true,
    "condition": { "type": "flag_set", "flag": "firstWebsiteContractOffered" },
    "dc": null,
    "outcomes": {
      "default": {
        "createWebsiteContract": {
          "contractId": "contract_website_001",
          "companyName": "Meridian Professional Services",
          "companyId": "company_meridian_services",
          "reward": 4500,
          "breachFee": 500,
          "requirements": {
            "minUxScore": 20,
            "requiredModules": ["hero_banner", "contact_form"]
          },
          "deadlineHours": 168
        },
        "setFlag": "firstWebsiteContractActive"
      }
    }
  }
]
